import Link from "next/link";
import { Card } from "@/components/ui/Card";
import { Button } from "@/components/ui/Button";
import { Input } from "@/components/ui/Input";
import { Label } from "@/components/ui/Label";
import { getUserAndProfile } from "@/lib/auth";
import { supabaseServer } from "@/lib/supabase/server";
import { env } from "@/lib/env";
import { createSeniorAndContacts } from "./actions";

function planPretty(status?: string | null, tier?: string | null, cadence?: string | null) {
  const s = status ?? "inactive";
  const t =
    tier === "facility" ? "Facility" : tier === "assurance" ? "Assurance" : tier === "checkin" ? "Check-In" : "None";
  const c = cadence === "annual" ? "Yearly" : cadence === "monthly" ? "Monthly" : "";
  if (s === "active") return `${t} • ${c}`;
  return "Not subscribed";
}

export default async function Page() {
  const { user, profile } = await getUserAndProfile();
  const sb = await supabaseServer();

  const { data: sub } = await sb.from("subscriptions").select("*").eq("user_id", user.id).maybeSingle();

  const { data: seniors } = await sb
    .from("seniors")
    .select("*")
    .order("created_at", { ascending: false });

  const senior = seniors?.[0] ?? null;

  const { data: invite } = senior
    ? await sb
        .from("invites")
        .select("*")
        .eq("senior_id", senior.id)
        .order("created_at", { ascending: false })
        .maybeSingle()
    : { data: null };

  const inviteUrl = invite?.token ? `${env.APP_BASE_URL}/dashboard?s=invite&token=${invite.token}` : null;

  const { data: recent } = senior
    ? await sb.from("checkins").select("*").eq("senior_id", senior.id).order("created_at", { ascending: false }).limit(8)
    : { data: null };

  const planLabel = planPretty(sub?.status, sub?.plan_tier, sub?.plan_cadence);

  return (
    <div className="space-y-8">
      {/* Header */}
      <div className="relative overflow-hidden rounded-[40px] border border-brand-blue/15 bg-white/70 p-6 shadow-soft">
        <div className="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-blue/10 blur-3xl" />
        <div className="absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-brand-lavender/15 blur-3xl" />

        <div className="relative flex flex-wrap items-start justify-between gap-4">
          <div>
            <div className="pill">Dashboard</div>
            <h1 className="mt-3 text-2xl font-semibold text-brand-navy md:text-3xl">
              Hi{profile?.name ? `, ${profile.name}` : ""}.
            </h1>
            <p className="mt-2 text-sm text-neutral-700">
              Manage check-ins, contacts, and escalation settings.
            </p>
          </div>

          <div className="flex flex-wrap items-center gap-2">
            <span className="rounded-full border border-brand-blue/15 bg-brand-blue/5 px-3 py-1 text-xs font-medium text-brand-navy">
              {planLabel}
            </span>
            <a href="/api/stripe/portal">
              <Button variant="ghost">Billing</Button>
            </a>
            <Link href="/pricing">
              <Button variant="soft">Upgrade</Button>
            </Link>
          </div>
        </div>
      </div>

      {!senior ? (
        <div className="grid gap-6 md:grid-cols-2">
          <Card>
            <div className="text-sm font-semibold text-brand-navy">Add your senior</div>
            <p className="mt-2 text-sm text-neutral-700">
              Set the name, phone number, and daily check-in time.
            </p>

            <form action={createSeniorAndContacts} className="mt-5 grid gap-4">
              <div className="grid gap-2">
                <Label>Senior name</Label>
                <Input name="senior_name" required placeholder="Mary Smith" />
              </div>

              <div className="grid gap-2">
                <Label>Senior phone (E.164)</Label>
                <Input name="phone_e164" required placeholder="+13525551234" />
              </div>

              <div className="grid gap-4 md:grid-cols-2">
                <div className="grid gap-2">
                  <Label>Timezone (IANA)</Label>
                  <Input name="timezone" defaultValue="America/New_York" required />
                </div>
                <div className="grid gap-2">
                  <Label>Check-in time (HH:MM)</Label>
                  <Input name="checkin_time" defaultValue="09:00" required />
                </div>
              </div>

              <div className="rounded-3xl border border-brand-blue/10 bg-brand-mist p-4">
                <div className="text-sm font-semibold text-brand-navy">Primary family contact</div>
                <p className="mt-1 text-xs text-neutral-600">
                  We’ll notify this person first if a check-in is missed.
                </p>

                <div className="mt-4 grid gap-4">
                  <div className="grid gap-2">
                    <Label>Name</Label>
                    <Input name="fc_name" required placeholder="Judd" />
                  </div>
                  <div className="grid gap-2">
                    <Label>Phone (E.164)</Label>
                    <Input name="fc_phone_e164" placeholder="+13525551234" />
                  </div>
                  <div className="grid gap-2">
                    <Label>Email</Label>
                    <Input name="fc_email" type="email" placeholder="optional" />
                  </div>
                </div>
              </div>

              <div className="space-y-2">
                <label className="flex items-start gap-3 rounded-3xl border border-neutral-200 bg-white p-4">
                  <input type="checkbox" name="consent" value="yes" required className="mt-1" />
                  <span className="text-sm text-neutral-700">
                    I confirm I have the senior’s consent to receive automated SMS/calls for check-ins and that they can
                    opt out by texting STOP.
                  </span>
                </label>
                <p className="text-xs text-neutral-500">
                  LifeSignal is not an emergency service. For emergencies, call local emergency services.
                </p>
              </div>

              <Button type="submit" className="w-full">Save & continue</Button>
            </form>
          </Card>

          <Card>
            <div className="text-sm font-semibold text-brand-navy">What happens next</div>
            <div className="mt-4 space-y-3 text-sm text-neutral-700">
              <p>• We’ll create the senior profile and your first family contact.</p>
              <p>• You’ll get a shareable invite link for additional contacts.</p>
              <p>• Once subscribed, check-ins will begin automatically.</p>
            </div>

            <div className="mt-6 rounded-3xl border border-neutral-200 bg-white p-5">
              <div className="text-xs text-neutral-500">Recommended first plan</div>
              <div className="mt-1 text-base font-semibold text-brand-navy">Check-In</div>
              <p className="mt-2 text-sm text-neutral-700">
                Perfect for one loved one. Upgrade anytime to add redundancy and more contacts.
              </p>
              <div className="mt-4">
                <Link href="/pricing">
                  <Button>View plans</Button>
                </Link>
              </div>
            </div>
          </Card>
        </div>
      ) : (
        <div className="grid gap-6 md:grid-cols-3">
          <Card className="md:col-span-2">
            <div className="flex flex-wrap items-start justify-between gap-3">
              <div>
                <div className="text-sm font-semibold text-brand-navy">Senior</div>
                <div className="mt-1 text-lg font-semibold text-brand-navy">{senior.name}</div>
                <div className="mt-1 text-sm text-neutral-700">
                  {senior.phone_e164} • {senior.timezone} • {senior.checkin_time}
                </div>
              </div>
              <div className="flex gap-2">
                <Link href="/pricing">
                  <Button variant="soft">Change plan</Button>
                </Link>
                <a href="/api/stripe/portal">
                  <Button variant="ghost">Manage billing</Button>
                </a>
              </div>
            </div>

            <div className="mt-6 grid gap-4 md:grid-cols-3">
              <div className="rounded-3xl border border-neutral-200 bg-white p-4">
                <div className="text-xs text-neutral-500">Channel</div>
                <div className="mt-1 font-semibold text-brand-navy">{String(senior.channel_pref).toUpperCase()}</div>
              </div>
              <div className="rounded-3xl border border-neutral-200 bg-white p-4">
                <div className="text-xs text-neutral-500">Wait window</div>
                <div className="mt-1 font-semibold text-brand-navy">{senior.wait_minutes} min</div>
              </div>
              <div className="rounded-3xl border border-neutral-200 bg-white p-4">
                <div className="text-xs text-neutral-500">Invite</div>
                <div className="mt-1 font-semibold text-brand-navy">{inviteUrl ? "Ready" : "—"}</div>
              </div>
            </div>

            {inviteUrl ? (
              <div className="mt-6 rounded-3xl border border-brand-blue/15 bg-brand-mist p-4">
                <div className="text-sm font-semibold text-brand-navy">Family invite link</div>
                <div className="mt-2 flex flex-wrap gap-2">
                  <Input readOnly value={inviteUrl} />
                  <a href={inviteUrl}>
                    <Button variant="soft">Open</Button>
                  </a>
                </div>
                <p className="mt-2 text-xs text-neutral-500">
                  Share this link with additional family contacts.
                </p>
              </div>
            ) : null}
          </Card>

          <Card>
            <div className="text-sm font-semibold text-brand-navy">Admin quick actions</div>
            <p className="mt-2 text-sm text-neutral-700">
              In production, schedule these endpoints with Vercel Cron or your external HTTP cron.
            </p>

            <div className="mt-4 space-y-3 rounded-3xl border border-neutral-200 bg-white p-4 text-xs text-neutral-700">
              <div className="font-semibold text-brand-navy">Run check-ins</div>
              <code className="block overflow-x-auto rounded-2xl bg-neutral-50 p-3">
                GET {env.APP_BASE_URL}/api/cron/run-checkins?token=YOUR_CRON_SECRET_TOKEN
              </code>

              <div className="font-semibold text-brand-navy">Run escalations</div>
              <code className="block overflow-x-auto rounded-2xl bg-neutral-50 p-3">
                GET {env.APP_BASE_URL}/api/cron/run-escalations?token=YOUR_CRON_SECRET_TOKEN
              </code>
            </div>

            <div className="mt-4 flex flex-wrap gap-2">
              <Link href="/pricing"><Button variant="soft">Upgrade plan</Button></Link>
              <a href="/api/stripe/portal"><Button variant="ghost">Manage billing</Button></a>
            </div>

            <p className="mt-3 text-xs text-neutral-500">
              Tokens should never be shared publicly.
            </p>
          </Card>

          <Card className="md:col-span-3">
            <div className="flex items-center justify-between">
              <div className="text-sm font-semibold text-brand-navy">Recent activity</div>
              <Link href="/pricing" className="text-sm text-neutral-600 hover:text-brand-navy hover:underline">
                View plans
              </Link>
            </div>

            <div className="mt-4 overflow-hidden rounded-3xl border border-neutral-200 bg-white">
              <div className="grid grid-cols-4 gap-2 border-b border-neutral-200 bg-neutral-50 px-4 py-3 text-xs font-medium text-neutral-600">
                <div>Date</div>
                <div>Status</div>
                <div>Channel</div>
                <div>Escalated</div>
              </div>

              <div className="divide-y divide-neutral-200">
                {(recent ?? []).length === 0 ? (
                  <div className="px-4 py-5 text-sm text-neutral-600">No activity yet.</div>
                ) : (
                  (recent ?? []).map((c: any) => (
                    <div key={c.id} className="grid grid-cols-4 gap-2 px-4 py-3 text-sm">
                      <div className="text-neutral-700">
                        {new Date(c.created_at).toLocaleString()}
                      </div>
                      <div className="font-medium text-brand-navy">{c.status}</div>
                      <div className="text-neutral-700">{c.channel}</div>
                      <div className="text-neutral-700">{c.escalated ? "Yes" : "No"}</div>
                    </div>
                  ))
                )}
              </div>
            </div>
          </Card>
        </div>
      )}
    </div>
  );
}
